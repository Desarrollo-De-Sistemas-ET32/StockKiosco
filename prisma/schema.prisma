generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model descuentos {
  id_descuento        Int           @id @default(autoincrement())
  tipo                TipoDescuento @default(PORCENTAJE)
  valor               Decimal       @db.Decimal(10, 2)
  fecha_creacion      DateTime      @default(now())
  fecha_actualizacion DateTime
  activo              Boolean       @default(true)
  descripcion         String?       @db.VarChar(255)
  fecha_fin           DateTime
  fecha_inicio        DateTime
  nombre              String        @db.VarChar(45)
}

model detalles_venta {
  id_detalle          Int       @id @default(autoincrement())
  id_venta            Int
  id_producto         Int
  cantidad            Int?
  precio_unitario     Decimal?  @db.Decimal(10, 2)
  subtotal            Decimal?  @db.Decimal(10, 2)
  fecha_creacion      DateTime  @default(now())
  fecha_actualizacion DateTime
  productos           productos @relation(fields: [id_producto], references: [id_producto])
  ventas              ventas    @relation(fields: [id_venta], references: [id_venta])
}

model marcas {
  id_marca     Int         @id @default(autoincrement())
  nombre_marca String      @db.VarChar(45)
  productos    productos[]
}

model pagos {
  id_pago             Int        @id @default(autoincrement())
  monto               Decimal    @db.Decimal(10, 2)
  id_venta            Int
  metodo_pago         MetodoPago
  fecha_pago          DateTime?
  fecha_creacion      DateTime   @default(now())
  fecha_actualizacion DateTime
  ventas              ventas     @relation(fields: [id_venta], references: [id_venta])
}

model productos {
  id_producto         Int              @id @default(autoincrement())
  nombre              String           @db.VarChar(36)
  id_proveedor        Int
  codigo_barra        Int?             @unique
  precio              Decimal          @db.Decimal(10, 2)
  fecha_creacion      DateTime         @default(now())
  fecha_actualizacion DateTime
  id_marca            Int?
  detalles_venta      detalles_venta[]
  marcas              marcas?          @relation(fields: [id_marca], references: [id_marca])
  proveedores         proveedores      @relation(fields: [id_proveedor], references: [id_proveedor])
  stock               stock[]
}

model proveedores {
  id_proveedor        Int         @id @default(autoincrement())
  nombre              String      @db.VarChar(45)
  contacto            String?     @db.VarChar(45)
  telefono            String?     @db.VarChar(45)
  email               String?     @db.VarChar(45)
  direccion           String?     @db.VarChar(45)
  fecha_creacion      DateTime    @default(now())
  fecha_actualizacion DateTime
  productos           productos[]
}

model stock {
  id_stock            Int       @id @default(autoincrement())
  id_producto         Int
  cantidad            Int?
  fecha_actualizacion DateTime
  productos           productos @relation(fields: [id_producto], references: [id_producto])
}

model usuarios {
  id_usuario          Int       @id @default(autoincrement())
  name                String    @db.VarChar(45)
  email               String    @unique @db.VarChar(70)
  password            String    @db.VarChar(255)
  fecha_creacion      DateTime  @default(now())
  fecha_actualizacion DateTime
  usuarios_roles      rolesUser @default(usuario)
  ventas              ventas[]
}

model ventas {
  id_venta            Int              @id @default(autoincrement())
  id_usuario          Int
  fecha_venta         DateTime         @default(now())
  total               Decimal?         @db.Decimal(10, 2)
  pagado              Boolean?         @default(false)
  fecha_creacion      DateTime         @default(now())
  fecha_actualizacion DateTime
  detalles_venta      detalles_venta[]
  pagos               pagos[]
  usuarios            usuarios         @relation(fields: [id_usuario], references: [id_usuario])
}

enum MetodoPago {
  efectivo
  tarjeta
  transferencia
}

enum TipoDescuento {
  PORCENTAJE
  MONTOFIJO
}

enum rolesUser {
  usuario
  administrador
}
